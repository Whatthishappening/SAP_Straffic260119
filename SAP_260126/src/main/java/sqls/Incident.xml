<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<!-- MyBatis는 Snake(_)인식이 안되므로 강제변환(resultmap) 사용-->
<mapper namespace="com.mbc.sap.dao.IncidentDao">

	<resultMap id="StatusResultMap" type="com.mbc.sap.dto.IncidentDto">
   	 <id column="incident_id" property="incident_id"/>
   	 <result column="incident_title" property="incident_title"/>
   	 <result column="incident_line_name" property="incident_line_name"/>
     <result column="incident_station_id" property="incident_station_id"/>
     <result column="incident_station_name" property="incident_station_name"/>
     <result column="incident_content" property="incident_content"/>
     <result column="incident_status" property="incident_status"/>
     <result column="incident_severity" property="incident_severity"/>
     <result column="user_id" property="user_id"/>
     <result column="user_name" property="user_name"/>
     <result column="create_at" property="create_at"/>
     <result column="complete_at" property="complete_at"/>
	</resultMap>
    
   <insert id="create_incident" parameterType="com.mbc.sap.dto.IncidentDto">
    INSERT INTO storage.incident (
        incident_title,
        incident_line_name,
        incident_station_id,
        incident_station_name,
        incident_content,
        incident_status,   incident_severity,
        user_id,
        user_name
    ) VALUES (
        #{incident_title}, 
        #{incident_line_name}, 
        #{incident_station_id}, 
        #{incident_station_name},
        #{incident_content},
        '1',               #{incident_severity},
        #{user_id},
        #{user_name}
    )
</insert>

<select id="get_incidentlist" parameterType="com.mbc.sap.dto.Incidentparam" resultMap="StatusResultMap">
    SELECT * FROM storage.incident
    <where>
        <if test="status == 'active'">
            AND incident_status IN ('1', '2')
        </if>
        <if test="status == 'resolved'">
            AND incident_status IN ('3', '4')
        </if>
        
        <if test="keyword != null and keyword != ''">
            AND incident_title LIKE CONCAT('%', #{keyword}, '%')
        </if>
    </where>
    ORDER BY incident_id DESC
    LIMIT 10 OFFSET ${(pageNumber * 10)}
</select>

<select id="count_incident" parameterType="com.mbc.sap.dto.Incidentparam" resultType="int">
    SELECT COUNT(*) 
    FROM storage.incident
    <where>
        incident_status IN ('1', '2')
        
        <if test="keyword != null and keyword != '' and category != null and category != ''">
            <choose>
                <when test="category == 'title'">
                    AND incident_title LIKE CONCAT('%', #{keyword}, '%')
                </when>
                <when test="category == 'writer'">
                    AND user_name = #{keyword}
                </when>
            </choose>
        </if>
    </where>
</select>

<select id="get_incident_detail" parameterType="String" resultMap="StatusResultMap">
    SELECT 
        incident_id,
        incident_title,
        incident_line_name,
        incident_station_id,
        incident_station_name,
        incident_content,
        incident_status,
        incident_severity,
        user_id,
        user_name,
        create_at,
        complete_at
    FROM storage.incident
    WHERE incident_id = #{incident_id}::INTEGER  </select>
</mapper>